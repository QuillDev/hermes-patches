 def load_picker_context() -> ConfigContext:
     """Load the disk-config snapshot every consumer needs.
 
@@ -105,6 +116,124 @@ def load_picker_context() -> ConfigContext:
     )
 
 
+def load_model_picker_filter() -> ModelPickerFilter | None:
+    """Load ``model_picker.allow`` from config.yaml, if configured.
+
+    Supported shapes::
+
+        model_picker:
+          allow:
+            openai-codex: [gpt-5.5]
+            zai: [glm-5.2]
+
+    and::
+
+        model_picker:
+          allow:
+            - provider: openai-codex
+              models: [gpt-5.5]
+            - provider: zai
+              model: glm-5.2
+    """
+    from hermes_cli.config import load_config
+
+    cfg = load_config()
+    section = cfg.get("model_picker") if isinstance(cfg, dict) else None
+    if not isinstance(section, dict):
+        return None
+    raw_allow = section.get("allow")
+    allow: dict[str, set[str]] = {}
+
+    def _provider_key(value: object) -> str:
+        try:
+            from hermes_cli.models import normalize_provider
+
+            return normalize_provider(str(value or ""))
+        except Exception:
+            return str(value or "").strip().lower()
+
+    def _add(provider: object, models: object) -> None:
+        provider_key = _provider_key(provider)
+        if not provider_key:
+            return
+        if isinstance(models, str):
+            values = [models]
+        elif isinstance(models, (list, tuple, set)):
+            values = list(models)
+        else:
+            values = []
+        cleaned = {str(model).strip() for model in values if str(model).strip()}
+        if cleaned:
+            allow.setdefault(provider_key, set()).update(cleaned)
+
+    if isinstance(raw_allow, dict):
+        for provider, models in raw_allow.items():
+            _add(provider, models)
+    elif isinstance(raw_allow, list):
+        for entry in raw_allow:
+            if not isinstance(entry, dict):
+                continue
+            models = entry.get("models", entry.get("model"))
+            _add(entry.get("provider", ""), models)
+
+    return ModelPickerFilter(allow=allow) if allow else None
+
+
+def apply_model_picker_filter(
+    rows: list[dict],
+    picker_filter: ModelPickerFilter | None,
+    *,
+    current_provider: str = "",
+    current_model: str = "",
+) -> tuple[list[dict], dict | None]:
+    """Apply provider-scoped model picker allowlist to provider rows."""
+    if picker_filter is None:
+        return rows, None
+
+    try:
+        from hermes_cli.models import normalize_provider
+    except Exception:
+        normalize_provider = None  # type: ignore[assignment]
+
+    def _provider_key(value: object) -> str:
+        raw = str(value or "").strip().lower()
+        if normalize_provider is None:
+            return raw
+        try:
+            return normalize_provider(raw)
+        except Exception:
+            return raw
+
+    filtered_rows: list[dict] = []
+    for row in rows:
+        slug = _provider_key(row.get("slug", ""))
+        allowed = picker_filter.allow.get(slug)
+        if not allowed:
+            continue
+        allowed_lower = {m.lower() for m in allowed}
+        visible_models = [
+            model
+            for model in (row.get("models") or [])
+            if str(model) in allowed or str(model).lower() in allowed_lower
+        ]
+        if not visible_models:
+            continue
+        next_row = dict(row)
+        next_row["models"] = visible_models
+        next_row["total_models"] = len(visible_models)
+        next_row["picker_filtered"] = True
+        filtered_rows.append(next_row)
+
+    current_key = _provider_key(current_provider)
+    current_allowed = False
+    if current_key in picker_filter.allow and current_model:
+        allowed = picker_filter.allow[current_key]
+        current_allowed = current_model in allowed or current_model.lower() in {
+            m.lower() for m in allowed
+        }
+    return filtered_rows, {"active": True, "current_allowed": bool(current_allowed)}
+
+
