+@dataclass(frozen=True)
+class ModelPickerFilter:
+    """Provider-scoped model allowlist for picker visibility.
+
+    The allowlist is deliberately picker-only: it hides provider/model pairs
+    from model-option payloads without blocking explicit ``/model`` switches.
+    """
+
+    allow: dict[str, set[str]]
+
