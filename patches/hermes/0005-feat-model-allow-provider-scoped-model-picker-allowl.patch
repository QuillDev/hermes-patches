+def test_model_picker_allowlist_filters_provider_scoped_model_pairs():
+    rows = [
+        {"slug": "openai-codex", "name": "OpenAI Codex", "models": ["gpt-5.5", "gpt-5.4"],
+         "total_models": 2, "is_current": True, "is_user_defined": False,
+         "source": "built-in"},
+        {"slug": "openai-api", "name": "OpenAI API", "models": ["gpt-5.5"],
+         "total_models": 1, "is_current": False, "is_user_defined": False,
+         "source": "built-in"},
+        {"slug": "nous", "name": "Nous", "models": ["openai/gpt-5.5", "z-ai/glm-5.2"],
+         "total_models": 2, "is_current": False, "is_user_defined": False,
+         "source": "built-in"},
+        {"slug": "zai", "name": "Z.AI", "models": ["glm-5.2", "glm-5.1"],
+         "total_models": 2, "is_current": False, "is_user_defined": False,
+         "source": "built-in"},
+    ]
+    cfg = {
+        "model_picker": {
+            "allow": {
+                "openai-codex": ["gpt-5.5"],
+                "zai": ["glm-5.2"],
+            }
+        }
+    }
+    ctx = _empty_ctx(provider="openai-codex", model="gpt-5.5")
+
+    with _list_auth_returning(rows), patch("hermes_cli.config.load_config", return_value=cfg):
+        payload = build_models_payload(ctx)
+
+    assert [(r["slug"], r["models"]) for r in payload["providers"]] == [
+        ("openai-codex", ["gpt-5.5"]),
+        ("zai", ["glm-5.2"]),
+    ]
+    assert payload["filter"] == {"active": True, "current_allowed": True}
+
+
+def test_model_picker_allowlist_accepts_list_shape_and_marks_current_hidden():
+    rows = [
+        {"slug": "openai-codex", "name": "OpenAI Codex", "models": ["gpt-5.5"],
+         "total_models": 1, "is_current": False, "is_user_defined": False,
+         "source": "built-in"},
+        {"slug": "zai", "name": "Z.AI", "models": ["glm-5.2", "glm-5.1"],
+         "total_models": 2, "is_current": False, "is_user_defined": False,
+         "source": "built-in"},
+    ]
+    cfg = {
+        "model_picker": {
+            "allow": [
+                {"provider": "openai-codex", "models": ["gpt-5.5"]},
+                {"provider": "zai", "model": "glm-5.2"},
+            ]
+        }
+    }
+    ctx = _empty_ctx(provider="zai", model="glm-5.1")
+
+    with _list_auth_returning(rows), patch("hermes_cli.config.load_config", return_value=cfg):
+        payload = build_models_payload(ctx, include_unconfigured=True)
+
+    assert [(r["slug"], r["models"]) for r in payload["providers"]] == [
+        ("openai-codex", ["gpt-5.5"]),
+        ("zai", ["glm-5.2"]),
+    ]
+    assert payload["filter"] == {"active": True, "current_allowed": False}
+
+
