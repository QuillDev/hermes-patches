+def _request_process_commands(body: Dict[str, Any]) -> bool:
+    """Return True when a session-chat request opts into slash-command handling."""
+    raw = body.get("process_commands", body.get("processCommands"))
+    if raw is None:
+        hermes_ext = body.get("hermes")
+        if isinstance(hermes_ext, dict):
+            raw = hermes_ext.get("process_commands", hermes_ext.get("processCommands"))
+    if isinstance(raw, str):
+        return raw.strip().lower() in {"1", "true", "yes", "on"}
+    return bool(raw)
+
+
+def _slash_command_text(user_message: Any) -> Optional[str]:
+    """Extract a leading slash command from normalized session-chat content."""
+    if isinstance(user_message, str):
+        text = user_message.strip()
+        return text if text.startswith("/") else None
+    if isinstance(user_message, list):
+        for part in user_message:
+            if not isinstance(part, dict):
+                continue
+            if str(part.get("type") or "").strip().lower() != "text":
+                continue
+            text = str(part.get("text") or "").strip()
+            return text if text.startswith("/") else None
+    return None
+
