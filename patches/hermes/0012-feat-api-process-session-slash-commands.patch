+    def _stored_session_model_override(self, session_id: str) -> Optional[Dict[str, Any]]:
+        """Return a request_model_override restored from session metadata."""
+        db = self._ensure_session_db()
+        try:
+            session = db.get_session(session_id)
+        except Exception:
+            return None
+        if not session:
+            return None
+        metadata = _json_object(session.get("model_config"))
+        model = str(metadata.get("model") or session.get("model") or "").strip()
+        provider = str(metadata.get("provider") or "").strip()
+        if not model:
+            return None
+
+        runtime: Dict[str, Any] = {}
+        if provider:
+            try:
+                from hermes_cli.runtime_provider import resolve_runtime_provider
+
+                runtime = resolve_runtime_provider(requested=provider, target_model=model)
+            except Exception as exc:
+                logger.debug(
+                    "Failed to resolve stored session model provider=%r model=%r: %s",
+                    provider,
+                    model,
+                    exc,
+                )
+                runtime = {}
+        for key in ("provider", "base_url", "api_mode"):
+            value = metadata.get(key)
+            if value:
+                runtime[key] = value
+        return {"model": model, "provider": provider, "runtime": runtime}
+
+    def _process_session_command(
+        self,
+        *,
+        session_id: str,
+        user_message: Any,
+        body: Dict[str, Any],
+    ) -> tuple[Optional[Dict[str, Any]], Optional["web.Response"]]:
+        """Handle opt-in API session slash commands before they reach the model."""
+        if not _request_process_commands(body):
+            return None, None
+        command_text = _slash_command_text(user_message)
+        if not command_text:
+            return None, None
+
+        command, _, raw_args = command_text[1:].partition(" ")
+        command = command.strip().lower()
+        if command != "model":
+            return None, web.json_response(
+                _openai_error(
+                    f"Unsupported session command: /{command}",
+                    code="unsupported_session_command",
+                    param="message",
+                ),
+                status=400,
+            )
+        return self._process_session_model_command(session_id=session_id, raw_args=raw_args)
+
+    def _process_session_model_command(
+        self,
+        *,
+        session_id: str,
+        raw_args: str,
+    ) -> tuple[Optional[Dict[str, Any]], Optional["web.Response"]]:
+        """Session-scoped /model handling for API-server chat endpoints."""
+        from gateway.run import _load_gateway_config, _resolve_gateway_model, _resolve_runtime_agent_kwargs
+        from hermes_cli.config import get_compatible_custom_providers
+        from hermes_cli.model_switch import parse_model_flags, switch_model
+
+        model_input, explicit_provider, _is_global, force_refresh, _is_session = parse_model_flags(raw_args)
+        if force_refresh:
+            try:
+                from hermes_cli.models import clear_provider_models_cache
+
+                clear_provider_models_cache()
+            except Exception:
+                pass
+
+        db = self._ensure_session_db()
+        session = db.get_session(session_id) or {}
+        metadata = _json_object(session.get("model_config"))
+
+        try:
+            user_config = _load_gateway_config()
+        except Exception:
+            user_config = {}
+        if not isinstance(user_config, dict):
+            user_config = {}
+
+        current_model = str(metadata.get("model") or session.get("model") or "").strip()
+        current_provider = str(metadata.get("provider") or "").strip()
+        current_base_url = str(metadata.get("base_url") or "").strip()
+        try:
+            runtime_kwargs = _resolve_runtime_agent_kwargs()
+        except Exception:
+            runtime_kwargs = {}
+        if not current_model:
+            current_model = str(runtime_kwargs.get("model") or _resolve_gateway_model(user_config) or "")
+        if not current_provider:
+            current_provider = str(runtime_kwargs.get("provider") or "")
+        if not current_base_url:
+            current_base_url = str(runtime_kwargs.get("base_url") or "")
+        current_api_key = str(runtime_kwargs.get("api_key") or "")
+
+        if not model_input and not explicit_provider:
+            content = f"Current model: {current_model or '(not configured)'}"
+            if current_provider:
+                content += f"\nProvider: {current_provider}"
+            content += "\nUsage: /model <model> [--provider <provider>]"
+            return {
+                "object": "hermes.session.command",
+                "session_id": session_id,
+                "command": "model",
+                "message": {"role": "assistant", "content": content},
+            }, None
+
+        result = switch_model(
+            raw_input=model_input,
+            current_provider=current_provider,
+            current_model=current_model,
+            current_base_url=current_base_url,
+            current_api_key=current_api_key,
+            is_global=False,
+            explicit_provider=explicit_provider,
+            user_providers=user_config.get("providers"),
+            custom_providers=get_compatible_custom_providers(user_config),
+        )
+        if not result.success:
+            return None, web.json_response(
+                _openai_error(result.error_message or "Invalid model selection", param="message"),
+                status=400,
+            )
+
+        metadata["model"] = result.new_model
+        metadata["provider"] = result.target_provider
+        if result.base_url:
+            metadata["base_url"] = result.base_url
+        else:
+            metadata.pop("base_url", None)
+        if result.api_mode:
+            metadata["api_mode"] = result.api_mode
+        else:
+            metadata.pop("api_mode", None)
+        for secret_key in ("api_key", "credential_pool", "command", "args"):
+            metadata.pop(secret_key, None)
+        db.update_session_meta(session_id, json.dumps(metadata), model=result.new_model)
+
+        provider_label = result.provider_label or result.target_provider
+        content = f"Switched session model to {result.new_model}"
+        if provider_label:
+            content += f" via {provider_label}"
+        return {
+            "object": "hermes.session.command",
+            "session_id": session_id,
+            "command": "model",
+            "model": result.new_model,
+            "provider": result.target_provider,
+            "message": {"role": "assistant", "content": content},
+        }, None
+
