+@pytest.mark.asyncio
+async def test_session_chat_process_commands_switches_model_without_agent_turn(
+    auth_adapter, session_db, monkeypatch
+):
+    """Opt-in command processing lets API clients use /model as control-plane input."""
+    session_id = session_db.create_session("command-session", "api_server", model="old-model")
+
+    from hermes_cli.model_switch import ModelSwitchResult
+
+    def fake_switch_model(**kwargs):
+        assert kwargs["raw_input"] == "gpt-5.5"
+        assert kwargs["explicit_provider"] == "openrouter"
+        return ModelSwitchResult(
+            success=True,
+            new_model="gpt-5.5",
+            target_provider="openrouter",
+            provider_label="OpenRouter",
+            api_key="sk-sec...ored",
+            base_url="https://openrouter.ai/api/v1",
+            api_mode="chat_completions",
+        )
+
+    monkeypatch.setattr("hermes_cli.model_switch.switch_model", fake_switch_model)
+
+    mock_run = AsyncMock(return_value=({"final_response": "should not run"}, {"total_tokens": 1}))
+    app = _create_session_app(auth_adapter)
+    with patch.object(auth_adapter, "_run_agent", mock_run):
+        async with TestClient(TestServer(app)) as cli:
+            resp = await cli.post(
+                f"/api/sessions/{session_id}/chat",
+                json={
+                    "message": "/model gpt-5.5 --provider openrouter",
+                    "process_commands": True,
+                },
+                headers={"Authorization": "Bearer sk-test"},
+            )
+            payload = await resp.json()
+
+    assert resp.status == 200
+    assert payload["object"] == "hermes.session.command"
+    assert payload["session_id"] == session_id
+    assert payload["command"] == "model"
+    assert "gpt-5.5" in payload["message"]["content"]
+    mock_run.assert_not_awaited()
+
+    stored = session_db.get_session(session_id)
+    assert stored["model"] == "gpt-5.5"
+    model_config = json.loads(stored["model_config"])
+    assert model_config["model"] == "gpt-5.5"
+    assert model_config["provider"] == "openrouter"
+    assert model_config["base_url"] == "https://openrouter.ai/api/v1"
+    assert "api_key" not in model_config
+
+
