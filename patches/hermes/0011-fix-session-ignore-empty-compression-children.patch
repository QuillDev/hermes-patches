Subject: [PATCH 11/21] fix(session): ignore empty compression children

Co-authored-by: Nako <280596805+nakoagent@users.noreply.github.com>

diff --git a/hermes_state.py b/hermes_state.py
index 088bc5cdc..74716f6fb 100644
--- a/hermes_state.py
+++ b/hermes_state.py
@@ -53,7 +53,9 @@ _BRANCH_CHILD_SQL = (
 _COMPRESSION_CHILD_SQL = (
     "EXISTS (SELECT 1 FROM sessions p"
     "        WHERE p.id = {a}.parent_session_id"
-    "        AND p.end_reason = 'compression')"
+    "        AND p.end_reason = 'compression'"
+    "        AND (COALESCE({a}.message_count, 0) > 0"
+    "             OR COALESCE({a}.api_call_count, 0) > 0))"
 )
 
 # Rows that surface in pickers: roots + branch children (subagent runs and
@@ -2781,11 +2783,12 @@ class SessionDB:
         The continuation edge is the canonical one shared with
         :func:`_ephemeral_child_sql` / :meth:`set_session_archived`
         (``_COMPRESSION_CHILD_SQL``): a parent → child edge counts only when the
-        parent ended with ``end_reason = 'compression'`` and the child started
-        at or after the parent's ``ended_at``, which distinguishes continuations
-        from delegate subagents / branch children that also carry a
-        ``parent_session_id``. Expressed as a single recursive CTE rather than a
-        per-hop Python walk so the edge definition lives in exactly one place.
+        parent ended with ``end_reason = 'compression'``, the child started at
+        or after the parent's ``ended_at``, and the child actually recorded
+        work. The final guard keeps abandoned empty client/API rows from
+        hijacking the projected live tip. Expressed as a single recursive CTE
+        rather than a per-hop Python walk so the edge definition lives in
+        exactly one place.
         """
         if not ancestor_id or not descendant_id or ancestor_id == descendant_id:
             return False
@@ -2889,6 +2892,8 @@ class SessionDB:
                     JOIN sessions child ON child.id = a.id
                     JOIN sessions parent ON parent.id = child.parent_session_id
                     WHERE parent.end_reason = 'compression'
+                      AND (COALESCE(child.message_count, 0) > 0
+                           OR COALESCE(child.api_call_count, 0) > 0)
                   ),
                   descendants(id) AS (
                     SELECT ?
@@ -2898,6 +2903,8 @@ class SessionDB:
                     JOIN sessions parent ON parent.id = d.id
                     JOIN sessions child ON child.parent_session_id = parent.id
                     WHERE parent.end_reason = 'compression'
+                      AND (COALESCE(child.message_count, 0) > 0
+                           OR COALESCE(child.api_call_count, 0) > 0)
                   ),
                   lineage(id) AS (
                     SELECT id FROM ancestors
@@ -2994,22 +3001,22 @@ class SessionDB:
         """Walk the compression-continuation chain forward and return the tip.
 
         A compression continuation is a child of a session whose
-        ``end_reason = 'compression'``.  Older builds tried to distinguish
-        continuations from branches/subagents by requiring
-        ``child.started_at >= parent.ended_at``.  That ordering is too brittle:
-        gateway + compression races can insert the real continuation row before
-        the parent row's ``ended_at`` is written, while a stale websocket later
-        creates/reuses a sibling that *does* satisfy the timestamp test.  The
-        visible symptom is brutal: desktop resume follows the stale sibling and
-        the user's latest messages look "lost" even though they are persisted in
-        the real continuation chain.
-
-        Instead, only follow children of compression-ended parents, exclude
-        explicit branch/delegate/tool children, and prefer children that are
-        themselves continuing the compression chain (``end_reason='compression'``)
-        or still live over stale closed siblings such as ``ws_orphan_reap``.
-        Returns the latest continuation tip, or the input id when no
-        continuation exists.
+        ``end_reason = 'compression'`` and that recorded work (messages or API
+        calls). Older builds tried to distinguish continuations from branches/
+        subagents by requiring ``child.started_at >= parent.ended_at``. That
+        ordering is too brittle: gateway + compression races can insert the real
+        continuation row before the parent row's ``ended_at`` is written, while
+        a stale websocket later creates/reuses a sibling that *does* satisfy the
+        timestamp test. The work guard ignores abandoned empty rows created by
+        client/API resume attempts, which otherwise sort newest and make old
+        conversations open as blank.
+
+        Instead, only follow non-empty children of compression-ended parents,
+        exclude explicit branch/delegate/tool children, and prefer children that
+        are themselves continuing the compression chain
+        (``end_reason='compression'``) or still live over stale closed siblings
+        such as ``ws_orphan_reap``. Returns the latest continuation tip, or the
+        input id when no continuation exists.
         """
         current = session_id
         seen = {current} if current else set()
@@ -3024,6 +3031,8 @@ class SessionDB:
                     JOIN sessions child ON child.parent_session_id = parent.id
                     WHERE parent.id = ?
                       AND parent.end_reason = 'compression'
+                      AND (COALESCE(child.message_count, 0) > 0
+                           OR COALESCE(child.api_call_count, 0) > 0)
                       AND json_extract(COALESCE(child.model_config, '{}'), '$._branched_from') IS NULL
                       AND json_extract(COALESCE(child.model_config, '{}'), '$._delegate_from') IS NULL
                       AND COALESCE(child.source, '') != 'tool'
@@ -3217,6 +3226,8 @@ class SessionDB:
                     JOIN sessions parent ON parent.id = c.cur_id
                     JOIN sessions child ON child.parent_session_id = c.cur_id
                     WHERE parent.end_reason = 'compression'
+                      AND (COALESCE(child.message_count, 0) > 0
+                           OR COALESCE(child.api_call_count, 0) > 0)
                       AND json_extract(COALESCE(child.model_config, '{{}}'), '$._branched_from') IS NULL
                       AND json_extract(COALESCE(child.model_config, '{{}}'), '$._delegate_from') IS NULL
                       AND COALESCE(child.source, '') != 'tool'
diff --git a/tests/hermes_state/test_session_archiving.py b/tests/hermes_state/test_session_archiving.py
index 36ecb95a1..c80cf6a44 100644
--- a/tests/hermes_state/test_session_archiving.py
+++ b/tests/hermes_state/test_session_archiving.py
@@ -49,3 +49,22 @@ def test_unarchiving_compression_tip_unarchives_projected_root(db):
     assert db.get_session("root")["archived"] == 0
     assert db.get_session("tip")["archived"] == 0
     assert [s["id"] for s in db.list_sessions_rich(order_by_last_active=True)] == ["tip"]
+
+
+def test_empty_newer_compression_child_does_not_hijack_projected_tip(db):
+    base = time.time() - 100
+    db.create_session("root", source="cli")
+    db.create_session("tip", source="cli", parent_session_id="root")
+    db.create_session("blank", source="api_server", parent_session_id="root")
+    db.append_message("tip", role="user", content="real continuation")
+    db._conn.execute(
+        "UPDATE sessions SET started_at = ?, ended_at = ?, end_reason = 'compression' WHERE id = 'root'",
+        (base, base + 10),
+    )
+    db._conn.execute("UPDATE sessions SET started_at = ? WHERE id = 'tip'", (base + 20,))
+    db._conn.execute("UPDATE sessions SET started_at = ? WHERE id = 'blank'", (base + 30,))
+    db._conn.commit()
+
+    assert db.get_compression_tip("root") == "tip"
+    assert db.resolve_resume_session_id("root") == "tip"
+    assert [s["id"] for s in db.list_sessions_rich(order_by_last_active=True)] == ["tip"]
