From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: robert-brunson-fragile <siinspam@gmail.com>
Date: Sat, 27 Jun 2026 13:05:51 -0700
Subject: [PATCH 16/17] fix(api): preserve session cwd binding after upstream
 sync

Co-authored-by: Nako <280596805+nakoagent@users.noreply.github.com>

diff --git a/gateway/platforms/api_server.py b/gateway/platforms/api_server.py
index 25c00c0ac..07b7c03ca 100644
--- a/gateway/platforms/api_server.py
+++ b/gateway/platforms/api_server.py
@@ -5577,6 +5577,7 @@ class APIServerAdapter(BasePlatformAdapter):
         chat_id: str = "",
         session_key: str = "",
         session_id: str = "",
+        cwd: str = "",
     ) -> list:
         """Bind session contextvars for an API-server agent run.
 
@@ -5600,6 +5601,7 @@ class APIServerAdapter(BasePlatformAdapter):
             chat_id=chat_id,
             session_key=session_key,
             session_id=session_id,
+            cwd=cwd,
             async_delivery=False,
         )
 
diff --git a/hermes_state.py b/hermes_state.py
index b54a33e3e..852de22c6 100644
--- a/hermes_state.py
+++ b/hermes_state.py
@@ -2394,21 +2394,14 @@ class SessionDB:
         """Return True if *ancestor_id* is a compression predecessor of
         *descendant_id* (walking parent links up the continuation chain).
 
-        The continuation edge is the canonical one shared with
-        :func:`_ephemeral_child_sql` / :meth:`set_session_archived`
-        (``_COMPRESSION_CHILD_SQL``): a parent → child edge counts only when the
-        parent ended with ``end_reason = 'compression'``, the child started at
-        or after the parent's ``ended_at``, and the child actually recorded
-        work. The final guard keeps abandoned empty client/API rows from
-        hijacking the projected live tip. Expressed as a single recursive CTE
-        rather than a per-hop Python walk so the edge definition lives in
-        exactly one place.
+        Title-transfer checks are intentionally broader than visible-tip
+        projection: test fixtures and older session rows may not have message or
+        API counts populated, but the parent-link still represents the same
+        compressed conversation. Keep branch/delegate/tool children excluded so
+        unrelated child sessions cannot steal a title from their parent.
         """
         if not ancestor_id or not descendant_id or ancestor_id == descendant_id:
             return False
-        # Walk parent links up from the descendant, following only compression
-        # continuation edges, and check whether ancestor_id is reached.
-        edge = _COMPRESSION_CHILD_SQL.format(a="child")
         row = conn.execute(
             f"""
             WITH RECURSIVE ancestors(id) AS (
@@ -2418,7 +2411,10 @@ class SessionDB:
                 FROM ancestors a
                 JOIN sessions child ON child.id = a.id
                 JOIN sessions parent ON parent.id = child.parent_session_id
-                WHERE {edge}
+                WHERE parent.end_reason = 'compression'
+                  AND json_extract(COALESCE(child.model_config, '{{}}'), '$._branched_from') IS NULL
+                  AND json_extract(COALESCE(child.model_config, '{{}}'), '$._delegate_from') IS NULL
+                  AND COALESCE(child.source, '') != 'tool'
             )
             SELECT 1 FROM ancestors WHERE id = ? AND id != ? LIMIT 1
             """,
-- 
2.52.0

