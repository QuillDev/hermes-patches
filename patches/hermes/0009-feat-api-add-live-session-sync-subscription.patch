+    def _session_response_with_activity(self, session: Dict[str, Any]) -> Dict[str, Any]:
+        """Return session metadata plus lightweight live-run state for clients."""
+        payload = self._session_response(session)
+        session_id = str(session.get("id") or payload.get("id") or "")
+        db = self._ensure_session_db()
+        stored_state = None
+        latest_event_cursor = None
+        if db is not None and session_id:
+            try:
+                stored_state = db.get_session_sync_state(session_id)
+                latest_event_cursor = db.latest_session_event_cursor(session_id)
+            except Exception:
+                stored_state = session.get("sync_state") if isinstance(session.get("sync_state"), dict) else None
+        else:
+            stored_state = session.get("sync_state") if isinstance(session.get("sync_state"), dict) else None
+        sync_state = self._live_session_state(session_id, stored_state)
+        latest_run = self._response_store.get_latest_session_run(session_id) if session_id else None
+        run_is_active = bool(
+            latest_run
+            and latest_run.get("status") in {"queued", "running", "waiting_for_approval", "stopping"}
+        )
+        if run_is_active:
+            sync_state["state"] = "processing"
+            sync_state["status"] = "processing"
+            sync_state["active"] = True
+            payload["active_run"] = latest_run
+        else:
+            payload["active_run"] = None
+            if sync_state.get("state") == "idle":
+                sync_state["active"] = False
+        payload["sync_state"] = sync_state
+        payload["active"] = bool(run_is_active or sync_state.get("state") == "processing")
+        payload["status"] = str(sync_state.get("status") or sync_state.get("state") or "idle")
+        payload["latest_event_cursor"] = latest_event_cursor
+        return payload
+
