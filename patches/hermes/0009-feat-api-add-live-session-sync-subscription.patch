+@pytest.mark.asyncio
+async def test_session_subscribe_sends_snapshot_and_replays_active_run(adapter, session_db):
+    import json as _json
+
+    session_id = session_db.create_session("subscribe-session", "api_server")
+    session_db.append_message(session_id, "user", "existing prompt")
+    session_db.append_message(session_id, "assistant", "existing answer")
+    adapter._response_store.create_session_run("run_subscribe", session_id, "live prompt")
+    adapter._response_store.put_session_run_event("run_subscribe", "run.started", {"status": "running"})
+    adapter._response_store.put_session_run_event(
+        "run_subscribe",
+        "assistant.delta",
+        {"message_id": "msg_live", "delta": "live delta"},
+    )
+
+    app = _create_session_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?once=true")
+        assert resp.status == 200
+        body = await resp.text()
+
+    events = []
+    for block in body.split("\n\n"):
+        if not block.strip() or block.startswith(":"):
+            continue
+        event_name = None
+        data = None
+        for line in block.splitlines():
+            if line.startswith("event: "):
+                event_name = line[len("event: "):]
+            elif line.startswith("data: "):
+                data = _json.loads(line[len("data: "):])
+        if event_name and data is not None:
+            events.append((event_name, data))
+
+    assert events[0][0] == "session.snapshot"
+    snapshot = events[0][1]
+    assert snapshot["session"]["id"] == session_id
+    assert [m["content"] for m in snapshot["messages"]] == ["existing prompt", "existing answer"]
+    assert snapshot["active_run"]["run_id"] == "run_subscribe"
+    assert [name for name, _ in events][1:] == ["run.started", "assistant.delta"]
+    assert events[-1][1]["delta"] == "live delta"
+
