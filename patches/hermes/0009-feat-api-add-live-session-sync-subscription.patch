+    async def _handle_session_subscribe(self, request: "web.Request") -> "web.StreamResponse":
+        """GET /api/sessions/{session_id}/subscribe — snapshot + live SSE."""
+        auth_err = self._check_auth(request)
+        if auth_err:
+            return auth_err
+        session_id = request.match_info["session_id"]
+        session, err = self._get_existing_session_or_404(session_id)
+        if err:
+            return err
+        db = self._ensure_session_db()
+        if db is None:
+            return web.json_response(_openai_error("Session database unavailable", code="session_db_unavailable"), status=503)
+
+        resolved_id = db.resolve_resume_session_id(session_id)
+        resolved_session = db.get_session(resolved_id) or session
+        explicit_cursor = request.query.get("after") or request.query.get("cursor")
+        session_cursor = explicit_cursor or db.latest_session_event_cursor(resolved_id) or "0"
+        try:
+            run_after = int(request.query.get("run_after") or request.query.get("after_seq") or "0")
+        except ValueError:
+            return web.json_response(_openai_error("run_after must be an integer", code="invalid_run_after"), status=400)
+        once = _coerce_request_bool(request.query.get("once"), default=False)
+
+        headers = {
+            "Content-Type": "text/event-stream",
+            "Cache-Control": "no-cache",
+            "X-Accel-Buffering": "no",
+            "X-Hermes-Session-Id": resolved_id,
+        }
+        origin = request.headers.get("Origin", "")
+        cors = self._cors_headers_for_origin(origin) if origin else None
+        if cors:
+            headers.update(cors)
+        response = web.StreamResponse(status=200, headers=headers)
+        await response.prepare(request)
+
+        async def _write_event(event_name: str, payload: Dict[str, Any]) -> None:
+            data = json.dumps(payload, ensure_ascii=False)
+            await response.write(f"event: {event_name}\ndata: {data}\n\n".encode("utf-8"))
+
+        latest_run = self._response_store.get_latest_session_run(resolved_id)
+        snapshot = {
+            "object": "hermes.session.snapshot",
+            "session_id": resolved_id,
+            "session": self._session_response(resolved_session),
+            "messages": [self._message_response(m) for m in db.get_messages(resolved_id)],
+            "items": db.get_session_items(resolved_id),
+            "latest_event_cursor": db.latest_session_event_cursor(resolved_id),
+            "active_run": latest_run,
+        }
+        active_run_id = latest_run.get("run_id") if latest_run else None
+        active_run_seq = run_after
+        last_activity = time.monotonic()
+
+        try:
+            await _write_event("session.snapshot", snapshot)
+            while True:
+                wrote = False
+                for event in db.list_session_events(session_id=resolved_id, after=session_cursor, limit=100):
+                    await _write_event(str(event.get("event_type") or "session.event"), event)
+                    session_cursor = event.get("cursor") or session_cursor
+                    wrote = True
+
+                latest_run = self._response_store.get_latest_session_run(resolved_id)
+                latest_run_id = latest_run.get("run_id") if latest_run else None
+                if latest_run_id and latest_run_id != active_run_id:
+                    active_run_id = latest_run_id
+                    active_run_seq = 0
+                    await _write_event("run.switch", {"session_id": resolved_id, "run": latest_run})
+                    wrote = True
+                if active_run_id:
+                    for item in self._response_store.list_session_run_events(active_run_id, after=active_run_seq):
+                        payload = item.get("payload") or {}
+                        active_run_seq = max(active_run_seq, int(payload.get("seq") or active_run_seq))
+                        await _write_event(str(item.get("event") or "run.event"), payload)
+                        wrote = True
+
+                if once:
+                    break
+                if wrote:
+                    last_activity = time.monotonic()
+                elif time.monotonic() - last_activity >= CHAT_COMPLETIONS_SSE_KEEPALIVE_SECONDS:
+                    await response.write(b": keepalive\n\n")
+                    last_activity = time.monotonic()
+                await asyncio.sleep(0.5)
+        except (asyncio.CancelledError, ConnectionResetError):
+            raise
+        except Exception as exc:
+            logger.debug("[api_server] session subscribe stream error for %s: %s", resolved_id, exc)
+        return response
+
