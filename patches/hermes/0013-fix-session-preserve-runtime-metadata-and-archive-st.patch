index 958801df1..373310004 100644
--- a/apps/desktop/src/store/session.ts
+++ b/apps/desktop/src/store/session.ts
@@ -116,6 +116,48 @@ function updateAtom<T>(store: AppAtom<T>, next: Updater<T>) {
 export const sessionPinId = (session: Pick<SessionInfo, '_lineage_root_id' | 'id'>): string =>
   session._lineage_root_id ?? session.id
 
+const OPTIMISTICALLY_HIDDEN_SESSION_TTL_MS = 30 * 1000
+const optimisticallyHiddenSessionExpiry = new Map<string, number>()
+
+function hiddenSessionKey(session: Pick<SessionInfo, '_lineage_root_id' | 'id'>): string {
+  return session._lineage_root_id ?? session.id
+}
+
+function getOptimisticallyHiddenSessionIds(now: number = Date.now()): Set<string> {
+  const live = new Set<string>()
+
+  for (const [id, expiry] of optimisticallyHiddenSessionExpiry) {
+    if (expiry > now) {
+      live.add(id)
+    } else {
+      optimisticallyHiddenSessionExpiry.delete(id)
+    }
+  }
+
+  return live
+}
+
+export function markSessionOptimisticallyHidden(
+  sessionId: string | null | undefined,
+  lineageRootId?: null | string
+): void {
+  const expiry = Date.now() + OPTIMISTICALLY_HIDDEN_SESSION_TTL_MS
+
+  if (sessionId) {
+    optimisticallyHiddenSessionExpiry.set(sessionId, expiry)
+  }
+
+  if (lineageRootId) {
+    optimisticallyHiddenSessionExpiry.set(lineageRootId, expiry)
+  }
+}
+
+export function clearSessionOptimisticallyHidden(sessionId: string | null | undefined): void {
+  if (sessionId) {
+    optimisticallyHiddenSessionExpiry.delete(sessionId)
+  }
+}
