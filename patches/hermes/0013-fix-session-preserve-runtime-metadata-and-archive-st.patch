+beforeEach(resetStores)
+afterEach(() => {
+  cleanup()
+  resetStores()
+})
+
+describe('AgentsView activity markers', () => {
+  it('shows active subagents with an amber loader and does not print completed status text', () => {
+    $subagentsBySession.set({
+      'session-1': [
+        baseSubagent({ goal: 'NaNotes Dev Setup', id: 'done-agent', status: 'completed', updatedAt: 1000 }),
+        baseSubagent({ goal: 'Gateway Session Archiving Support', id: 'running-agent', status: 'running', updatedAt: 2000 })
+      ]
+    })
+
+    render(<AgentsView onClose={() => undefined} />)
+
+    expect(screen.getByText('NaNotes Dev Setup')).toBeTruthy()
+    expect(screen.getByText('Gateway Session Archiving Support')).toBeTruthy()
+    expect(screen.getByRole('status', { name: 'Running' })).toBeTruthy()
+    expect(screen.queryByText(/completed/i)).toBeNull()
+    expect(screen.queryByLabelText('Done')).toBeNull()
+  })
+})
