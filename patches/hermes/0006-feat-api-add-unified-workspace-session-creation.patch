+    async def _handle_create_workspace(self, request: "web.Request") -> "web.Response":
+        """POST /v1/workspaces — register a local git repository for worktree sessions.
+
+        The initial API-server workspace contract is intentionally stateless: the
+        workspace id encodes the canonical local repo path, and session metadata
+        stores the actual worktree path.  This keeps the downstream Nako support
+        patch small and avoids a new workspace table/migration.
+        """
+        auth_err = self._check_auth(request)
+        if auth_err:
+            return auth_err
+        body, err = await self._read_json_body(request)
+        if err:
+            return err
+        raw_path = body.get("repo_path") or body.get("repoPath") or body.get("path")
+        if not isinstance(raw_path, str) or not raw_path.strip():
+            return web.json_response(_openai_error("repo_path is required", code="missing_repo_path"), status=400)
+        repo_path = Path(raw_path).expanduser().resolve()
+        if not repo_path.exists() or not repo_path.is_dir():
+            return web.json_response(_openai_error(f"Repository path does not exist: {repo_path}", code="repo_not_found"), status=400)
+        try:
+            workspace = await asyncio.to_thread(_workspace_payload, repo_path)
+        except subprocess.CalledProcessError as exc:
+            detail = (exc.stderr or exc.stdout or str(exc)).strip()
+            return web.json_response(_openai_error(f"Not a git repository: {detail}", code="not_git_repository"), status=400)
+        return web.json_response(workspace, status=201)
+
+    async def _handle_create_unified_session(self, request: "web.Request") -> "web.Response":
+        """POST /v1/sessions — create a chat or worktree-backed API session."""
+        auth_err = self._check_auth(request)
+        if auth_err:
+            return auth_err
+        body, err = await self._read_json_body(request)
+        if err:
+            return err
+        session_type = str(body.get("type") or "chat").strip().lower()
+        if session_type in {"chat", "session", "cwd"}:
+            return await self._create_unified_chat_session(body)
+        if session_type == "worktree":
+            return await self._create_unified_worktree_session(body)
+        return web.json_response(_openai_error(f"Unsupported session type: {session_type}", code="unsupported_session_type"), status=400)
+
+    async def _create_unified_chat_session(self, body: Dict[str, Any]) -> "web.Response":
+        db = self._ensure_session_db()
+        if db is None:
+            return web.json_response(_openai_error("Session database unavailable", code="session_db_unavailable"), status=503)
+        cwd, err = self._validated_optional_cwd(body.get("cwd"))
+        if err is not None:
+            return err
+        session_id, err = self._new_client_session_id(body)
+        if err is not None:
+            return err
+        model = body.get("model") or self._model_name
+        system_prompt = body.get("system_prompt") or body.get("systemPrompt")
+        if system_prompt is not None and not isinstance(system_prompt, str):
+            return web.json_response(_openai_error("system_prompt must be a string", code="invalid_system_prompt"), status=400)
+        source = self._client_session_source(body)
+        try:
+            db.create_session(session_id, source, model=str(model) if model else None, system_prompt=system_prompt, cwd=cwd)
+        except Exception as exc:
+            logger.exception("Failed to create unified chat session")
+            return web.json_response(_openai_error(f"Failed to create session: {exc}", err_type="server_error"), status=500)
+        title_err = self._apply_session_title(db, session_id, body.get("title"))
+        if title_err is not None:
+            return title_err
+        session = db.get_session(session_id) or {"id": session_id, "source": source, "model": model, "title": body.get("title"), "cwd": cwd}
+        return web.json_response(self._session_response(session), status=201)
+
+    async def _create_unified_worktree_session(self, body: Dict[str, Any]) -> "web.Response":
+        db = self._ensure_session_db()
+        if db is None:
+            return web.json_response(_openai_error("Session database unavailable", code="session_db_unavailable"), status=503)
+        workspace_id = body.get("workspace") or body.get("workspace_id") or body.get("workspaceId")
+        repo_path = _repo_path_from_workspace_id(str(workspace_id or ""))
+        if repo_path is None:
+            return web.json_response(_openai_error("workspace must be a valid local workspace id", code="invalid_workspace"), status=400)
+        try:
+            workspace = await asyncio.to_thread(_workspace_payload, repo_path)
+        except subprocess.CalledProcessError as exc:
+            detail = (exc.stderr or exc.stdout or str(exc)).strip()
+            return web.json_response(_openai_error(f"Workspace repository unavailable: {detail}", code="workspace_unavailable"), status=400)
+        session_id, err = self._new_client_session_id(body)
+        if err is not None:
+            return err
+        branch_name = str(body.get("branch_name") or body.get("branchName") or f"nako-{uuid.uuid4().hex[:8]}").strip()
+        if not branch_name or not _SAFE_GIT_BRANCH_RE.match(branch_name):
+            return web.json_response(_openai_error("branch_name must contain only letters, numbers, '.', '_' or '-'", code="invalid_branch_name"), status=400)
+        base_ref = str(body.get("base_ref") or body.get("baseRef") or workspace.get("defaultBranch") or "HEAD").strip()
+        worktrees_path = Path(str(workspace["worktreesPath"]))
+        worktree_path = worktrees_path / branch_name
+        if worktree_path.exists():
+            return web.json_response(_openai_error(f"Worktree path already exists: {worktree_path}", code="worktree_exists"), status=409)
+        try:
+            await asyncio.to_thread(self._create_git_worktree, Path(str(workspace["repoPath"])), worktree_path, branch_name, base_ref)
+        except subprocess.CalledProcessError as exc:
+            detail = (exc.stderr or exc.stdout or str(exc)).strip()
+            return web.json_response(_openai_error(f"Failed to create worktree: {detail}", code="worktree_create_failed"), status=400)
+        metadata = {
+            "nako_worktree": {
+                "workspace_id": workspace["id"],
+                "repo_path": workspace["repoPath"],
+                "worktree_path": str(worktree_path),
+                "branch_name": branch_name,
+                "base_ref": base_ref,
+            }
+        }
+        model = body.get("model") or self._model_name
+        system_prompt = body.get("system_prompt") or body.get("systemPrompt")
+        if system_prompt is not None and not isinstance(system_prompt, str):
+            return web.json_response(_openai_error("system_prompt must be a string", code="invalid_system_prompt"), status=400)
+        source = self._client_session_source(body)
+        try:
+            db.create_session(
+                session_id,
+                source,
+                model=str(model) if model else None,
+                model_config=metadata,
+                system_prompt=system_prompt,
+                cwd=str(worktree_path),
+            )
+        except Exception as exc:
+            logger.exception("Failed to create unified worktree session")
+            return web.json_response(_openai_error(f"Failed to create session: {exc}", err_type="server_error"), status=500)
+        title_err = self._apply_session_title(db, session_id, body.get("title"))
+        if title_err is not None:
+            return title_err
+        session = db.get_session(session_id) or {"id": session_id, "source": source, "model": model, "title": body.get("title"), "cwd": str(worktree_path), "model_config": metadata}
+        return web.json_response(self._session_response(session), status=201)
+
+    @staticmethod
+    def _create_git_worktree(repo_path: Path, worktree_path: Path, branch_name: str, base_ref: str) -> None:
+        worktree_path.parent.mkdir(parents=True, exist_ok=True)
+        _run_git(repo_path, "worktree", "add", "-b", branch_name, str(worktree_path), base_ref)
+
+    @staticmethod
+    def _client_session_source(body: Dict[str, Any]) -> str:
+        source = str(body.get("source") or "api_server").strip() or "api_server"
+        return "api_server" if re.search(r'[\r\n\x00]', source) else source[:64]
+
+    def _new_client_session_id(self, body: Dict[str, Any]) -> tuple[Optional[str], Optional["web.Response"]]:
+        raw_id = body.get("id") or body.get("session_id") or body.get("sessionId")
+        session_id = str(raw_id).strip() if raw_id else f"api_{int(time.time())}_{uuid.uuid4().hex[:8]}"
+        if not session_id or re.search(r'[\r\n\x00]', session_id):
+            return None, web.json_response(_openai_error("Invalid session ID", code="invalid_session_id"), status=400)
+        if len(session_id) > self._MAX_SESSION_HEADER_LEN:
+            return None, web.json_response(_openai_error("Session ID too long", code="invalid_session_id"), status=400)
+        db = self._ensure_session_db()
+        if db is not None and db.get_session(session_id):
+            return None, web.json_response(_openai_error(f"Session already exists: {session_id}", code="session_exists"), status=409)
+        return session_id, None
+
+    @staticmethod
+    def _validated_optional_cwd(raw_cwd: Any) -> tuple[Optional[str], Optional["web.Response"]]:
+        if raw_cwd is None or str(raw_cwd).strip() == "":
+            return None, None
+        if not isinstance(raw_cwd, str):
+            return None, web.json_response(_openai_error("cwd must be a string", code="invalid_cwd"), status=400)
+        cwd = Path(raw_cwd).expanduser().resolve()
+        if not cwd.is_dir():
+            return None, web.json_response(_openai_error(f"cwd does not exist: {cwd}", code="invalid_cwd"), status=400)
+        return str(cwd), None
+
+    @staticmethod
+    def _apply_session_title(db: Any, session_id: str, title: Any) -> Optional["web.Response"]:
+        if title is None:
+            return None
+        try:
+            db.set_session_title(session_id, str(title))
+        except ValueError as exc:
+            db.delete_session(session_id)
+            return web.json_response(_openai_error(str(exc), code="invalid_title"), status=400)
+        return None
+
