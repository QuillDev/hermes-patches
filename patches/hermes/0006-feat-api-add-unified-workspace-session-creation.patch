+def _workspace_id_for_repo(repo_path: Path) -> str:
+    raw = str(repo_path.resolve()).encode("utf-8")
+    encoded = base64.urlsafe_b64encode(raw).decode("ascii").rstrip("=")
+    return f"{_LOCAL_WORKSPACE_ID_PREFIX}{encoded}"
+
+
+def _repo_path_from_workspace_id(workspace_id: str) -> Optional[Path]:
+    if not isinstance(workspace_id, str) or not workspace_id.startswith(_LOCAL_WORKSPACE_ID_PREFIX):
+        return None
+    encoded = workspace_id[len(_LOCAL_WORKSPACE_ID_PREFIX):]
+    if not encoded:
+        return None
+    try:
+        padded = encoded + ("=" * (-len(encoded) % 4))
+        decoded = base64.urlsafe_b64decode(padded.encode("ascii")).decode("utf-8")
+        return Path(decoded).expanduser().resolve()
+    except Exception:
+        return None
+
+
+def _run_git(repo_path: Path, *args: str) -> subprocess.CompletedProcess[str]:
+    return subprocess.run(
+        ["git", "-C", str(repo_path), *args],
+        check=True,
+        capture_output=True,
+        text=True,
+    )
+
+
+def _git_repo_root(repo_path: Path) -> Path:
+    result = _run_git(repo_path, "rev-parse", "--show-toplevel")
+    return Path(result.stdout.strip()).expanduser().resolve()
+
+
+def _git_default_branch(repo_path: Path) -> str:
+    probes = (
+        ("symbolic-ref", "--quiet", "--short", "refs/remotes/origin/HEAD"),
+        ("branch", "--show-current"),
+    )
+    for args in probes:
+        try:
+            value = _run_git(repo_path, *args).stdout.strip()
+        except subprocess.CalledProcessError:
+            continue
+        if value:
+            return value.removeprefix("origin/") if args[0] == "symbolic-ref" else value
+    return "HEAD"
+
+
+def _workspace_payload(repo_path: Path) -> Dict[str, Any]:
+    root = _git_repo_root(repo_path)
+    worktrees_path = root.parent / f"{root.name}-worktrees"
+    return {
+        "object": "workspace",
+        "id": _workspace_id_for_repo(root),
+        "name": root.name,
+        "repoPath": str(root),
+        "worktreesPath": str(worktrees_path),
+        "defaultBranch": _git_default_branch(root),
+    }
+
