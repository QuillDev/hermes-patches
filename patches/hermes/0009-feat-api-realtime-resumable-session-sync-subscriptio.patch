+class TestSessionEventListeners:
+    """Module-level wakeup hooks fired after session_events writes commit."""
+
+    def test_listener_fires_for_event_writers(self, db):
+        db.create_session("s1", "cli")
+        seen = []
+        hermes_state.register_session_event_listener(seen.append)
+        try:
+            db.append_message("s1", "user", "hello")
+            assert seen == ["s1"]
+
+            db.append_session_event("s1", "session.custom", {"k": "v"})
+            assert seen == ["s1", "s1"]
+
+            db.end_session("s1", "done")
+            db.reopen_session("s1")
+            assert seen == ["s1"] * 4
+
+            db.replace_messages("s1", [{"role": "user", "content": "rewritten"}])
+            assert seen == ["s1"] * 5
+
+            db.archive_and_compact("s1", [{"role": "user", "content": "compacted"}])
+            assert seen == ["s1"] * 6
+        finally:
+            hermes_state.unregister_session_event_listener(seen.append)
+
+    def test_raising_listener_does_not_break_writes(self, db):
+        db.create_session("s1", "cli")
+
+        def _explode(session_id):
+            raise RuntimeError("listener bug")
+
+        hermes_state.register_session_event_listener(_explode)
+        try:
+            msg_id = db.append_message("s1", "user", "still persisted")
+            assert msg_id > 0
+            assert db.get_messages("s1")[-1]["content"] == "still persisted"
+        finally:
+            hermes_state.unregister_session_event_listener(_explode)
+
+    def test_unregistered_listener_stops_firing(self, db):
+        db.create_session("s1", "cli")
+        seen = []
+
+        def _listener(session_id):
+            seen.append(session_id)
+
+        hermes_state.register_session_event_listener(_listener)
+        db.append_message("s1", "user", "one")
+        hermes_state.unregister_session_event_listener(_listener)
+        db.append_message("s1", "user", "two")
+        assert seen == ["s1"]
+
+    def test_listener_fires_across_instances_sharing_a_db(self, tmp_path):
+        """The registry is module-level: a write through ANY SessionDB
+        instance (the agent constructs its own) must wake listeners."""
