+@pytest.mark.asyncio
+async def test_append_message_from_thread_wakes_subscriber(adapter, session_db):
+    """Real path: the agent persists a message on an executor thread through
+    the module-level hermes_state listener hook, and a connected subscriber
+    receives the durable item without waiting out the poll interval."""
+    session_id = session_db.create_session("thread-wake-session", "api_server")
+    adapter._SUBSCRIBE_POLL_INTERVAL = 30.0
+    # Registration normally happens in _ensure_session_db on first handler use;
+    # the subscribe request below triggers it.
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe")
+        await _read_frames_until(resp, lambda f: f["event"] == "session.snapshot")
+
+        def _write_from_thread():
+            # A second SessionDB instance over the same state.db — the agent
+            # never shares the adapter's instance.
+            agent_db = SessionDB(session_db.db_path)
+            try:
+                agent_db.append_message(session_id, "assistant", "written off-loop")
+            finally:
+                agent_db.close()
+
+        thread = threading.Thread(target=_write_from_thread)
+        thread.start()
+        try:
+            frames = await _read_frames_until(
+                resp,
+                lambda f: f["event"] == "session.item.upserted"
+                and "written off-loop" in json.dumps(f["data"]),
+                timeout=10.0,
+            )
+        finally:
+            thread.join(timeout=5)
+    assert frames
+
+
+@pytest.mark.asyncio
+async def test_restart_interruption_visible_to_resuming_and_fresh_clients(
+    adapter, session_db, tmp_path
+):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?after=0&once=true")
+        resume_token = _parse_sse(await resp.text())[-1]["id"]
+
+        # Simulate a server restart: a new ResponseStore over the same file
+        # runs startup recovery in __init__.
+        adapter._response_store.close()
+        adapter._response_store = ResponseStore(
+            db_path=str(tmp_path / "response_store.db")
+        )
+
+        # A client resuming from its pre-restart cursor replays the synthetic
+        # terminal event instead of hanging on a run that will never finish.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?resume={resume_token}&once=true"
+        )
+        resumed_frames = _parse_sse(await resp.text())
+        interrupted = [f for f in resumed_frames if f["event"] == "run.interrupted"]
+        assert len(interrupted) == 1
+        assert interrupted[0]["data"]["run_id"] == run_id
+        assert interrupted[0]["data"]["status"] == "interrupted"
+
+        # A fresh client sees the truth in the snapshot.
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?once=true")
+        snapshot = _parse_sse(await resp.text())[0]
+        assert snapshot["data"]["active_run"]["status"] == "interrupted"
+
