+class SessionSyncNotifier:
+    """Per-session wakeup fanout for /subscribe streams.
+
+    Each subscriber registers its own asyncio.Event so concurrent subscribers
+    never race on a shared flag. ``notify()`` is safe to call from executor
+    threads (agent callbacks) — it marshals onto the bound event loop. When no
+    loop is bound (unit tests calling handlers directly, pre-startup writes)
+    it silently no-ops and subscribers fall back to their poll interval.
+    """
+
+    def __init__(self) -> None:
+        self._loop: Optional[asyncio.AbstractEventLoop] = None
+        self._waiters: Dict[str, set] = {}
+
+    def bind_loop(self, loop: "asyncio.AbstractEventLoop") -> None:
+        self._loop = loop
+
+    def attach(self, session_id: str) -> "asyncio.Event":
+        if self._loop is None:
+            # Subscribers only exist on a running loop; self-bind so streams
+            # served without an explicit bind_loop() (tests, embedded apps)
+            # still get push wakeups.
+            try:
+                self._loop = asyncio.get_running_loop()
+            except RuntimeError:
+                pass
+        event = asyncio.Event()
+        self._waiters.setdefault(session_id, set()).add(event)
+        return event
+
+    def detach(self, session_id: str, event: "asyncio.Event") -> None:
+        waiters = self._waiters.get(session_id)
+        if not waiters:
+            return
+        waiters.discard(event)
+        if not waiters:
+            self._waiters.pop(session_id, None)
+
+    def notify(self, session_id: str) -> None:
+        loop = self._loop
+        if loop is None or not session_id:
+            return
+        try:
+            loop.call_soon_threadsafe(self._set_all, session_id)
+        except RuntimeError:
+            # Loop already closed (shutdown) — poll fallback covers stragglers.
+            pass
+
+    def _set_all(self, session_id: str) -> None:
+        for event in tuple(self._waiters.get(session_id, ())):
+            event.set()
+
+
+_SYNC_CURSOR_VERSION = "v1"
+
+
+def _encode_sync_cursor(session_cursor: Any, run_id: Optional[str], run_seq: Any) -> str:
+    """Encode the composite resume token carried as the SSE ``id:`` field.
+
+    Format: ``v1:<session_event_cursor>:<run_id>:<run_seq>``. run_ids never
+    contain colons; an empty run_id slot means "no active run observed yet".
+    """
+    return (
+        f"{_SYNC_CURSOR_VERSION}:{session_cursor or '0'}:{run_id or ''}:{int(run_seq or 0)}"
+    )
+
+
+def _parse_sync_cursor(token: Any) -> Optional[tuple[str, Optional[str], int]]:
+    """Parse a composite sync cursor; returns (session_cursor, run_id, run_seq).
+
+    Accepts a bare integer as a legacy session-event cursor (run state
+    defaults). Returns None for anything unparseable so callers can decide
+    between a 400 (explicit param) and a silent ignore (Last-Event-ID).
+    """
+    if token is None:
+        return None
+    text = str(token).strip()
+    if not text:
+        return None
+    if text.isdigit():
+        return text, None, 0
+    parts = text.split(":", 3)
+    if len(parts) != 4 or parts[0] != _SYNC_CURSOR_VERSION:
+        return None
