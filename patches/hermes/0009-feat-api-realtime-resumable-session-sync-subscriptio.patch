+"""Behavioral tests for the durable, realtime, resumable session sync engine.
+
+Covers the /api/sessions/{id}/subscribe protocol: composite resume cursors
+carried as SSE ids, Last-Event-ID reconnects, legacy cursor params,
+multi-client fanout, push (notifier) wakeups beating the poll fallback, and
+server-restart interruption visibility. See docs/api-session-sync.md.
+"""
+
+import asyncio
+import json
+import threading
+
+import pytest
+from aiohttp import web
+from aiohttp.test_utils import TestClient, TestServer
+
+import hermes_state
+from gateway.config import PlatformConfig
+from gateway.platforms.api_server import (
+    APIServerAdapter,
+    ResponseStore,
+    _encode_sync_cursor,
+    _parse_sync_cursor,
+)
+from hermes_state import SessionDB
+
+
+@pytest.fixture
+def session_db(tmp_path):
+    db = SessionDB(tmp_path / "state.db")
+    try:
+        yield db
+    finally:
+        db.close()
+
+
+@pytest.fixture
+def adapter(session_db, tmp_path):
+    adapter = APIServerAdapter(PlatformConfig(enabled=True))
+    adapter._response_store.close()
+    adapter._response_store = ResponseStore(db_path=str(tmp_path / "response_store.db"))
+    adapter._session_db = session_db
+    try:
+        yield adapter
+    finally:
+        adapter._response_store.close()
+        # _ensure_session_db registers the adapter's notifier in the
+        # module-level hermes_state listener registry; drop it so adapters
+        # never leak across tests.
+        hermes_state.unregister_session_event_listener(adapter._sync_notifier.notify)
+
+
+def _create_app(adapter: APIServerAdapter) -> web.Application:
+    app = web.Application()
+    app.router.add_get(
+        "/api/sessions/{session_id}/subscribe", adapter._handle_session_subscribe
+    )
+    return app
+
+
+def _parse_sse(raw: str) -> list:
+    """Parse SSE text into a list of {id, event, data} frames."""
+    frames = []
+    for block in raw.split("\n\n"):
+        frame = {"id": None, "event": None, "data": None}
+        for line in block.splitlines():
+            if line.startswith("id: "):
+                frame["id"] = line[len("id: "):]
+            elif line.startswith("event: "):
+                frame["event"] = line[len("event: "):]
+            elif line.startswith("data: "):
+                frame["data"] = json.loads(line[len("data: "):])
+        if frame["event"] is not None:
+            frames.append(frame)
+    return frames
+
+
+async def _read_frames_until(resp, predicate, timeout=5.0):
+    """Incrementally read SSE frames from a live stream until predicate hits."""
+    frames = []
+    buffer = b""
+    loop = asyncio.get_running_loop()
+    deadline = loop.time() + timeout
+    while True:
+        remaining = deadline - loop.time()
+        if remaining <= 0:
+            raise AssertionError(f"predicate not satisfied; frames so far: {frames}")
+        chunk = await asyncio.wait_for(resp.content.read(4096), timeout=remaining)
+        if not chunk:
+            raise AssertionError(f"stream closed early; frames so far: {frames}")
+        buffer += chunk
+        while b"\n\n" in buffer:
+            block, buffer = buffer.split(b"\n\n", 1)
+            parsed = _parse_sse(block.decode("utf-8") + "\n\n")
+            frames.extend(parsed)
+            for frame in parsed:
+                if predicate(frame):
+                    return frames
+
+
+def _seed_session_with_run(session_db, response_store, name="sync-session"):
+    session_id = session_db.create_session(name, "api_server")
+    session_db.append_message(session_id, "user", "hello")
+    session_db.append_message(session_id, "assistant", "hi there")
+    run_id = "run_sync_test"
+    response_store.create_session_run(run_id, session_id, "hello")
+    response_store.put_session_run_event(run_id, "run.started", {"status": "running"})
+    response_store.put_session_run_event(
+        run_id, "assistant.delta", {"message_id": "msg_1", "delta": "hi "}
+    )
+    response_store.put_session_run_event(
+        run_id, "assistant.delta", {"message_id": "msg_1", "delta": "there"}
+    )
+    return session_id, run_id
+
+
+def test_sync_cursor_roundtrip_and_legacy_forms():
+    token = _encode_sync_cursor("42", "run_abc", 7)
+    assert _parse_sync_cursor(token) == ("42", "run_abc", 7)
+    # No active run: empty run slot decodes to None.
+    assert _parse_sync_cursor(_encode_sync_cursor("9", None, 0)) == ("9", None, 0)
+    # Bare integers are legacy session-event cursors.
+    assert _parse_sync_cursor("123") == ("123", None, 0)
+    # Garbage is rejected, not misparsed.
+    assert _parse_sync_cursor("v2:1:x:0") is None
+    assert _parse_sync_cursor("v1:not-a-number:run:0") is None
+    assert _parse_sync_cursor("") is None
+    assert _parse_sync_cursor(None) is None
+
+
+@pytest.mark.asyncio
+async def test_subscribe_frames_carry_composite_cursor_id(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?after=0&once=true")
+        assert resp.status == 200
+        frames = _parse_sse(await resp.text())
+
+    assert frames, "expected at least the snapshot frame"
+    assert frames[0]["event"] == "session.snapshot"
+    for frame in frames:
+        parsed = _parse_sync_cursor(frame["id"])
+        assert parsed is not None, f"frame without a valid id: {frame}"
+    # The final frame's id reflects everything delivered: the latest durable
+    # cursor and the last replayed run seq.
+    final_cursor, final_run_id, final_seq = _parse_sync_cursor(frames[-1]["id"])
+    assert final_cursor == session_db.latest_session_event_cursor(session_id)
+    assert final_run_id == run_id
+    assert final_seq == adapter._response_store.get_session_run(run_id)["last_seq"]
+    # The snapshot payload also exposes the token for non-EventSource clients.
+    assert _parse_sync_cursor(frames[0]["data"]["cursor"]) is not None
+
+
+@pytest.mark.asyncio
+async def test_resume_from_composite_cursor_skips_replayed_events(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?after=0&once=true")
+        first_frames = _parse_sse(await resp.text())
+        resume_token = first_frames[-1]["id"]
+        first_deltas = [
+            f["data"]["delta"]
+            for f in first_frames
+            if f["event"] == "assistant.delta"
+        ]
+        assert first_deltas == ["hi ", "there"]
+
+        # New activity lands after the client disconnected.
+        session_db.append_message(session_id, "user", "follow-up question")
+        adapter._response_store.put_session_run_event(
+            run_id, "assistant.delta", {"message_id": "msg_1", "delta": "!"}
+        )
+
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?resume={resume_token}&once=true"
+        )
+        assert resp.status == 200
+        resumed_frames = _parse_sse(await resp.text())
+
+    resumed_deltas = [
+        f["data"]["delta"] for f in resumed_frames if f["event"] == "assistant.delta"
+    ]
+    assert resumed_deltas == ["!"], "already-consumed deltas must not be replayed"
+    resumed_items = [
+        f for f in resumed_frames if f["event"] == "session.item.upserted"
+    ]
+    contents = json.dumps([f["data"] for f in resumed_items])
+    assert "follow-up question" in contents
+    assert "hi there" not in contents, "pre-cursor durable events must not be replayed"
+
+
+@pytest.mark.asyncio
+async def test_last_event_id_header_beats_stale_query_params(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe?after=0&once=true")
+        resume_token = _parse_sse(await resp.text())[-1]["id"]
+
+        adapter._response_store.put_session_run_event(
+            run_id, "assistant.delta", {"message_id": "msg_1", "delta": "new"}
+        )
+
+        # An EventSource reconnect re-sends the ORIGINAL query string but adds
+        # Last-Event-ID; the header must win or the client replays everything.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?after=0&once=true",
+            headers={"Last-Event-ID": resume_token},
+        )
+        frames = _parse_sse(await resp.text())
+
+    deltas = [f["data"]["delta"] for f in frames if f["event"] == "assistant.delta"]
+    assert deltas == ["new"]
+
+
+@pytest.mark.asyncio
+async def test_legacy_after_and_run_after_params_still_work(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+    latest_cursor = session_db.latest_session_event_cursor(session_id)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        # Bare-integer after + run_after replay only what's past each cursor.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?after={latest_cursor}&run_after=2&once=true"
+        )
+        frames = _parse_sse(await resp.text())
+        deltas = [f["data"]["delta"] for f in frames if f["event"] == "assistant.delta"]
+        assert deltas == ["there"], "run_after=2 must skip seqs 1-2"
+        assert not [f for f in frames if f["event"] == "session.item.upserted"]
+
+        # after_seq is an accepted alias, and cursor an alias for after.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?cursor={latest_cursor}&after_seq=3&once=true"
+        )
+        frames = _parse_sse(await resp.text())
+        assert not [f for f in frames if f["event"] == "assistant.delta"]
+
+        # A malformed run_after is a 400, not a silent default.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?run_after=nope&once=true"
+        )
+        assert resp.status == 400
+        # As is a malformed resume token.
+        resp = await cli.get(
+            f"/api/sessions/{session_id}/subscribe?resume=v9:bogus&once=true"
+        )
+        assert resp.status == 400
+
+
+@pytest.mark.asyncio
+async def test_multi_client_concurrent_subscribe_both_receive_events(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        resp_a = await cli.get(f"/api/sessions/{session_id}/subscribe")
+        resp_b = await cli.get(f"/api/sessions/{session_id}/subscribe")
+        assert resp_a.status == 200 and resp_b.status == 200
+
+        def is_live_delta(frame):
+            return (
+                frame["event"] == "assistant.delta"
+                and frame["data"].get("delta") == "broadcast"
+            )
+
+        # Give both streams their snapshots before writing.
+        await _read_frames_until(resp_a, lambda f: f["event"] == "session.snapshot")
+        await _read_frames_until(resp_b, lambda f: f["event"] == "session.snapshot")
+
+        adapter._response_store.put_session_run_event(
+            run_id, "assistant.delta", {"message_id": "msg_1", "delta": "broadcast"}
+        )
+        adapter._sync_notifier.notify(session_id)
+
+        frames_a, frames_b = await asyncio.gather(
+            _read_frames_until(resp_a, is_live_delta),
+            _read_frames_until(resp_b, is_live_delta),
+        )
+
+    assert any(is_live_delta(f) for f in frames_a)
+    assert any(is_live_delta(f) for f in frames_b)
+
