+@pytest.mark.asyncio
+async def test_join_in_progress_replays_run_and_switches_to_new_run(adapter, session_db):
+    session_id, run_id = _seed_session_with_run(session_db, adapter._response_store)
+
+    app = _create_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        # A client joining mid-run gets the snapshot plus the full in-flight
+        # run replay by default (run_after defaults to 0).
+        resp = await cli.get(f"/api/sessions/{session_id}/subscribe")
+        frames = await _read_frames_until(
+            resp,
+            lambda f: f["event"] == "assistant.delta"
+            and f["data"].get("delta") == "there",
+        )
+        assert frames[0]["event"] == "session.snapshot"
+        assert frames[0]["data"]["active_run"]["run_id"] == run_id
+        deltas = [f["data"]["delta"] for f in frames if f["event"] == "assistant.delta"]
+        assert deltas == ["hi ", "there"]
+
+        # When a new run starts, live subscribers get run.switch and then the
+        # new run's events from seq 0.
+        adapter._response_store.create_session_run(
+            "run_sync_next", session_id, "next turn"
+        )
+        adapter._response_store.put_session_run_event(
+            "run_sync_next", "run.started", {"status": "running"}
+        )
+        adapter._sync_notifier.notify(session_id)
+
+        frames = await _read_frames_until(
+            resp,
+            lambda f: f["event"] == "run.started"
+            and f["data"].get("run_id") == "run_sync_next",
+        )
