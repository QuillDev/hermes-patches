+    @pytest.mark.asyncio
+    async def test_stop_records_terminal_durable_event(self, adapter):
+        """After stop, the durable run record must reach a terminal state so
+        subscribers/replayers don't render the run as live forever."""
+        app = _create_runs_app(adapter)
+        async with TestClient(TestServer(app)) as cli:
+            with patch.object(adapter, "_create_agent") as mock_create:
+                mock_agent, agent_ready, _ = _make_slow_agent()
+                mock_create.return_value = mock_agent
+
+                # Start run
+                resp = await cli.post("/v1/runs", json={"input": "hello"})
+                assert resp.status == 202
+                data = await resp.json()
+                run_id = data["run_id"]
+
+                agent_ready.wait(timeout=3.0)
+                await asyncio.sleep(0.1)
+
+                # Stop the run
+                stop_resp = await cli.post(f"/v1/runs/{run_id}/stop")
+                assert stop_resp.status == 200
+
+                terminal = {"completed", "failed", "interrupted"}
+                for _ in range(100):
+                    stored = adapter._response_store.get_session_run(run_id)
+                    if stored and stored["status"] in terminal:
+                        break
+                    await asyncio.sleep(0.05)
+                assert stored is not None
+                assert stored["status"] in terminal
+                event_names = [
+                    e["event"]
+                    for e in adapter._response_store.list_session_run_events(run_id)
+                ]
+                assert any(
+                    name in {"run.completed", "run.failed", "run.cancelled"}
+                    for name in event_names
+                )
