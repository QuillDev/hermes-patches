+    @pytest.mark.asyncio
+    async def test_run_events_persisted_durably_and_status_pollable(self, adapter):
+        """Run lifecycle events land in ResponseStore so any client can
+        replay them (via /subscribe) after the run — no live stream needed."""
+        app = _create_runs_app(adapter)
+        async with TestClient(TestServer(app)) as cli:
+            with patch.object(adapter, "_create_agent") as mock_create:
+                mock_agent = MagicMock()
+                mock_agent.run_conversation.return_value = {"final_response": "Hello!"}
+                mock_agent.session_prompt_tokens = 10
+                mock_agent.session_completion_tokens = 5
+                mock_agent.session_total_tokens = 15
+                mock_create.return_value = mock_agent
 
+                resp = await cli.post("/v1/runs", json={"input": "hello"})
+                assert resp.status == 202
+                data = await resp.json()
+                run_id = data["run_id"]
+                # The 202 exposes the session to subscribe to.
+                assert data["session_id"]
+
+                for _ in range(100):
+                    status_resp = await cli.get(f"/v1/runs/{run_id}")
+                    status = await status_resp.json()
+                    if status["status"] == "completed":
+                        break
+                    await asyncio.sleep(0.05)
+                assert status["status"] == "completed"
+
+        stored_run = adapter._response_store.get_session_run(run_id)
+        assert stored_run is not None
+        assert stored_run["status"] == "completed"
+        assert stored_run["session_id"] == data["session_id"]
+        events = adapter._response_store.list_session_run_events(run_id)
+        event_names = [e["event"] for e in events]
+        assert "run.started" in event_names
+        assert "run.completed" in event_names
+        completed = next(e for e in events if e["event"] == "run.completed")
+        assert completed["payload"]["output"] == "Hello!"
 
