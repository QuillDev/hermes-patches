+    def _apply_requested_model_selection(
+        self,
+        metadata: Dict[str, Any],
+        body: Dict[str, Any],
+    ) -> tuple[Dict[str, Any], Optional["web.Response"]]:
+        """Apply an explicit create-time ``model``/``provider`` selection.
+
+        Create endpoints snapshot the gateway's current runtime into session
+        metadata; when the client asks for a specific model this resolves the
+        selection through ``switch_model`` (same pipeline as the session
+        ``/model`` command) and overwrites the snapshot so future turns run on
+        the requested model. Returns ``(metadata, error_response)``.
+        """
+        requested_model = body.get("model")
+        requested_provider = body.get("provider")
+        if requested_model is not None and not isinstance(requested_model, str):
+            return metadata, web.json_response(
+                _openai_error("'model' must be a string", param="model"), status=400
+            )
+        if requested_provider is not None and not isinstance(requested_provider, str):
+            return metadata, web.json_response(
+                _openai_error("'provider' must be a string", param="provider"), status=400
+            )
+        model_input = str(requested_model or "").strip()
+        explicit_provider = str(requested_provider or "").strip()
+        # OpenAI-compatible clients echo the advertised model id back; only an
+        # actual selection should override the runtime snapshot.
+        if not model_input or model_input == self._model_name:
+            if explicit_provider and not model_input:
+                return metadata, web.json_response(
+                    _openai_error("'model' is required when 'provider' is supplied", param="model"),
+                    status=400,
+                )
+            return metadata, None
+
+        from gateway.run import _load_gateway_config, _resolve_runtime_agent_kwargs
+        from hermes_cli.config import get_compatible_custom_providers
+        from hermes_cli.model_switch import switch_model
+
+        try:
+            user_config = _load_gateway_config()
+        except Exception:
+            user_config = {}
+        if not isinstance(user_config, dict):
+            user_config = {}
+        try:
+            runtime_kwargs = _resolve_runtime_agent_kwargs()
+        except Exception:
+            runtime_kwargs = {}
+
+        result = switch_model(
+            raw_input=model_input,
+            current_provider=str(metadata.get("provider") or runtime_kwargs.get("provider") or ""),
+            current_model=str(metadata.get("model") or runtime_kwargs.get("model") or ""),
+            current_base_url=str(metadata.get("base_url") or runtime_kwargs.get("base_url") or ""),
+            current_api_key=str(runtime_kwargs.get("api_key") or ""),
+            is_global=False,
+            explicit_provider=explicit_provider or None,
+            user_providers=user_config.get("providers"),
+            custom_providers=get_compatible_custom_providers(user_config),
+        )
+        if not result.success:
+            return metadata, web.json_response(
+                _openai_error(result.error_message or "Invalid model selection", param="model"),
+                status=400,
+            )
+
+        metadata = dict(metadata)
+        metadata["model"] = result.new_model
+        metadata["provider"] = result.target_provider
+        if result.base_url:
+            metadata["base_url"] = result.base_url
+        else:
+            metadata.pop("base_url", None)
+        if result.api_mode:
+            metadata["api_mode"] = result.api_mode
+        else:
+            metadata.pop("api_mode", None)
+        for secret_key in ("api_key", "credential_pool", "command", "args"):
+            metadata.pop(secret_key, None)
+        return metadata, None
+
