+    async def _handle_providers(self, request: "web.Request") -> "web.Response":
+        """GET /v1/providers — authenticated providers and their curated models.
+
+        Exposes the same catalog the CLI/gateway ``/model`` picker uses so
+        external UIs can offer a model selector without duplicating the
+        provider/credential detection logic. ``?refresh=1`` busts the cached
+        per-provider model lists (explicit user-triggered refresh only).
+        """
+        auth_err = self._check_auth(request)
+        if auth_err:
+            return auth_err
+        refresh = str(request.query.get("refresh") or "").strip().lower() in {"1", "true", "yes"}
+
+        def _load() -> tuple[str, str, list]:
+            from gateway.run import _load_gateway_config, _resolve_gateway_model, _resolve_runtime_agent_kwargs
+            from hermes_cli.config import get_compatible_custom_providers
+            from hermes_cli.inventory import apply_model_picker_filter, load_model_picker_filter
+            from hermes_cli.model_switch import list_authenticated_providers
+
+            try:
+                user_config = _load_gateway_config()
+            except Exception:
+                user_config = {}
+            if not isinstance(user_config, dict):
+                user_config = {}
+            try:
+                runtime_kwargs = _resolve_runtime_agent_kwargs()
+            except Exception:
+                runtime_kwargs = {}
+            current_model = str(runtime_kwargs.get("model") or _resolve_gateway_model(user_config) or "").strip()
+            current_provider = str(runtime_kwargs.get("provider") or "").strip()
+            current_base_url = str(runtime_kwargs.get("base_url") or "").strip()
+            providers = list_authenticated_providers(
+                current_provider=current_provider,
+                current_base_url=current_base_url,
+                current_model=current_model,
+                user_providers=user_config.get("providers"),
+                custom_providers=get_compatible_custom_providers(user_config),
+                refresh=refresh,
+            )
+            # Honor the same ``model_picker.allow`` whitelist the TUI/``hermes
+            # model`` picker applies (see inventory.build_models_payload). Without
+            # this the external /v1/providers catalog exposed every authenticated
+            # provider, diverging from the curated CLI picker that external UIs
+            # (desktop model selector) are meant to mirror.
+            picker_filter = load_model_picker_filter()
+            if picker_filter is not None:
+                providers, _ = apply_model_picker_filter(
+                    providers,
+                    picker_filter,
+                    current_provider=current_provider,
+                    current_model=current_model,
+                )
+            return current_model, current_provider, providers
+
+        try:
+            current_model, current_provider, providers = await asyncio.to_thread(_load)
+        except Exception as exc:
+            logger.exception("Failed to list providers")
+            return web.json_response(
+                _openai_error(f"Failed to list providers: {exc}", err_type="server_error"),
+                status=500,
+            )
+        return web.json_response({
+            "object": "hermes.providers",
+            "current": {"model": current_model, "provider": current_provider},
+            "providers": [
+                {
+                    "slug": p.get("slug"),
+                    "name": p.get("name"),
+                    "models": list(p.get("models") or []),
+                    "total_models": p.get("total_models"),
+                    "is_current": bool(p.get("is_current")),
+                    "source": p.get("source"),
+                }
+                for p in providers
+            ],
+        })
+
