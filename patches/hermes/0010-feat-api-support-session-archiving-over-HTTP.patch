From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: robert-brunson-fragile <siinspam@gmail.com>
Date: Sat, 20 Jun 2026 21:13:32 -0700
Subject: [PATCH 10/15] feat(api): support session archiving over HTTP

Expose soft session archive state through the gateway API server so clients can archive, unarchive, and filter session lists without using the dashboard-only API.

Co-authored-by: Nako <280596805+nakoagent@users.noreply.github.com>

diff --git a/gateway/platforms/api_server.py b/gateway/platforms/api_server.py
index 69b75b65c..6a4332eea 100644
--- a/gateway/platforms/api_server.py
+++ b/gateway/platforms/api_server.py
@@ -1606,6 +1606,7 @@ class APIServerAdapter(BasePlatformAdapter):
                 "session_run_replay": True,
                 "session_subscribe_sse": True,
                 "session_fork": True,
+                "session_archiving": True,
                 "unified_session_create": True,
                 "workspace_resources": True,
                 "admin_config_rw": False,
@@ -1758,9 +1759,11 @@ class APIServerAdapter(BasePlatformAdapter):
             "output_tokens", "cache_read_tokens", "cache_write_tokens",
             "reasoning_tokens", "estimated_cost_usd", "actual_cost_usd",
             "api_call_count", "parent_session_id", "last_active", "preview", "cwd",
-            "_lineage_root_id",
+            "archived", "_lineage_root_id",
         )
         payload = {key: session.get(key) for key in safe_keys if key in session}
+        if "archived" in payload:
+            payload["archived"] = bool(payload["archived"])
         metadata = _json_object(session.get("model_config"))
         worktree = metadata.get("nako_worktree") if isinstance(metadata.get("nako_worktree"), dict) else None
         if worktree:
@@ -2349,12 +2352,28 @@ class APIServerAdapter(BasePlatformAdapter):
         offset = self._parse_nonnegative_int(request.query.get("offset"), default=0, maximum=1_000_000)
         source = request.query.get("source") or None
         include_children = _coerce_request_bool(request.query.get("include_children"), default=False)
+        archived_filter = (request.query.get("archived") or "false").strip().lower()
+        include_archived = False
+        archived_only = False
+        if archived_filter in _FALSE_REQUEST_BOOL_STRINGS or archived_filter == "exclude":
+            include_archived = False
+        elif archived_filter in _TRUE_REQUEST_BOOL_STRINGS or archived_filter in {"include", "all"}:
+            include_archived = True
+        elif archived_filter in {"only", "archived"}:
+            archived_only = True
+        else:
+            return web.json_response(
+                _openai_error("archived must be false, true, exclude, include, or only", code="invalid_archived_filter"),
+                status=400,
+            )
         sessions = db.list_sessions_rich(
             source=source,
             limit=limit,
             offset=offset,
             include_children=include_children,
             order_by_last_active=True,
+            include_archived=include_archived,
+            archived_only=archived_only,
         )
         return web.json_response({
             "object": "list",
@@ -2423,12 +2442,14 @@ class APIServerAdapter(BasePlatformAdapter):
         body, err = await self._read_json_body(request)
         if err:
             return err
-        allowed = {"title", "end_reason"}
+        allowed = {"title", "end_reason", "archived"}
         unknown = sorted(set(body) - allowed)
         if unknown:
             return web.json_response(_openai_error(f"Unsupported session fields: {', '.join(unknown)}", code="unsupported_session_field"), status=400)
 
         db = self._ensure_session_db()
+        if db is None:
+            return web.json_response(_openai_error("Session database unavailable", code="session_db_unavailable"), status=503)
         if "title" in body:
             try:
                 db.set_session_title(session_id, "" if body["title"] is None else str(body["title"]))
@@ -2436,6 +2457,22 @@ class APIServerAdapter(BasePlatformAdapter):
                 return web.json_response(_openai_error(str(exc), code="invalid_title"), status=400)
         if body.get("end_reason"):
             db.end_session(session_id, str(body["end_reason"]))
+        if "archived" in body:
+            archived_value = body["archived"]
+            if isinstance(archived_value, bool):
+                archived = archived_value
+            elif isinstance(archived_value, str) and archived_value.strip().lower() in _TRUE_REQUEST_BOOL_STRINGS:
+                archived = True
+            elif isinstance(archived_value, str) and archived_value.strip().lower() in _FALSE_REQUEST_BOOL_STRINGS:
+                archived = False
+            elif isinstance(archived_value, (int, float)):
+                archived = bool(archived_value)
+            else:
+                return web.json_response(
+                    _openai_error("archived must be a boolean", code="invalid_archived"),
+                    status=400,
+                )
+            db.set_session_archived(session_id, archived)
         session = db.get_session(session_id) or session
         return web.json_response({"object": "hermes.session", "session": self._session_response(session)})
 
