+@pytest.mark.asyncio
+async def test_session_patch_archives_and_unarchives(adapter, session_db):
+    session_id = session_db.create_session("archive-session", "api_server")
+    session_db.append_message(session_id, "user", "hide me")
+
+    app = _create_session_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        archive_resp = await cli.patch(f"/api/sessions/{session_id}", json={"archived": True})
+        assert archive_resp.status == 200
+        archived = await archive_resp.json()
+
+        hidden_resp = await cli.get("/api/sessions?archived=false")
+        assert hidden_resp.status == 200
+        hidden = await hidden_resp.json()
+
+        only_resp = await cli.get("/api/sessions?archived=only")
+        assert only_resp.status == 200
+        only = await only_resp.json()
+
+        include_resp = await cli.get("/api/sessions?archived=true")
+        assert include_resp.status == 200
+        include = await include_resp.json()
+
+        unarchive_resp = await cli.patch(f"/api/sessions/{session_id}", json={"archived": False})
+        assert unarchive_resp.status == 200
+        unarchived = await unarchive_resp.json()
+
+        visible_resp = await cli.get("/api/sessions?archived=false")
+        assert visible_resp.status == 200
+        visible = await visible_resp.json()
+
+    assert archived["session"]["archived"] is True
+    assert session_db.get_session(session_id)["archived"] == 0
+    assert all(s["id"] != session_id for s in hidden["data"])
+    assert [s["id"] for s in only["data"]] == [session_id]
+    assert [s["id"] for s in include["data"]] == [session_id]
+    assert unarchived["session"]["archived"] is False
+    assert [s["id"] for s in visible["data"]] == [session_id]
+
+
+@pytest.mark.asyncio
+async def test_session_archive_rejects_invalid_values(adapter, session_db):
+    session_id = session_db.create_session("archive-invalid", "api_server")
+    app = _create_session_app(adapter)
+    async with TestClient(TestServer(app)) as cli:
+        patch_resp = await cli.patch(f"/api/sessions/{session_id}", json={"archived": "sometimes"})
+        list_resp = await cli.get("/api/sessions?archived=sometimes")
+
+    assert patch_resp.status == 400
+    assert list_resp.status == 400
+
+
