+from __future__ import annotations
+
+import json
+import subprocess
+from types import SimpleNamespace
+
+from plugins.image_gen.civitai import (
+    CivitaiImageGenProvider,
+    _build_workflow,
+    _call_api,
+    _clean_env_without_proxies,
+    _extract_image_url,
+    _MODELS,
+)
+
+
+def test_civitai_provider_defaults_to_janku_text_only():
+    provider = CivitaiImageGenProvider()
+
+    assert provider.name == "civitai"
+    assert provider.default_model() == "janku"
+    assert provider.capabilities() == {"modalities": ["text"], "max_reference_images": 0}
+    assert [row["id"] for row in provider.list_models()] == ["illustrious", "janku"]
+
+
+def test_build_workflow_uses_sdxl_ecosystem_for_illustrious_and_loras():
+    loras = {"urn:air:sdxl:lora:civitai:2613391@2963607": 0.8}
+
+    workflow, width, height = _build_workflow(
+        prompt="anime puppy girl",
+        aspect="portrait",
+        model_meta=_MODELS["janku"],
+        negative_prompt="low quality",
+        loras=loras,
+        quantity=3,
+        steps=28,
+        cfg_scale="3.5",
+        seed="1234",
+    )
+
+    step_input = workflow["steps"][0]["input"]
+    assert width == 832
+    assert height == 1216
+    assert step_input["engine"] == "sdcpp"
+    assert step_input["ecosystem"] == "sdxl"
+    assert step_input["model"] == "urn:air:sdxl:checkpoint:civitai:1277670@2786084"
+    assert step_input["prompt"] == "anime puppy girl"
+    assert step_input["negativePrompt"] == "low quality"
+    assert step_input["loras"] == loras
+    assert step_input["quantity"] == 3
+    assert step_input["steps"] == 28
+    assert step_input["cfgScale"] == 3.5
+    assert step_input["seed"] == 1234
+
+
+def test_generate_reports_missing_key_without_network(monkeypatch):
+    monkeypatch.delenv("CIVITAI_API_KEY", raising=False)
+
+    result = CivitaiImageGenProvider().generate("draw something", model="illustrious")
+
+    assert result["success"] is False
+    assert result["error_type"] == "auth_required"
+    assert result["model"] == "illustrious"
+
+
+def test_generate_rejects_image_to_image_with_clear_error(monkeypatch):
+    monkeypatch.setenv("CIVITAI_API_KEY", "test-key")
+
+    result = CivitaiImageGenProvider().generate(
+        "edit this",
+        image_url="/tmp/source.png",
+    )
+
+    assert result["success"] is False
+    assert result["error_type"] == "modality_unsupported"
+    assert "text-to-image only" in result["error"]
+
+
+def test_generate_success_uses_requested_model_and_extracts_buzz(monkeypatch):
+    from plugins.image_gen import civitai
+
+    monkeypatch.setenv("CIVITAI_API_KEY", "test-key")
+
+    def fake_call_api(api_key, workflow, wait=civitai.DEFAULT_WAIT):
+        assert api_key == "test-key"
+        step_input = workflow["steps"][0]["input"]
+        assert step_input["model"] == "urn:air:sdxl:checkpoint:civitai:1277670@2786084"
+        return {
+            "id": "wf_123",
+            "status": "succeeded",
+            "cost": {"total": 5},
+            "steps": [{"output": {"images": [{"url": "https://example.invalid/out.jpg"}]}}],
+        }
+
+    monkeypatch.setattr(civitai, "_call_api", fake_call_api)
+
+    result = CivitaiImageGenProvider().generate("draw", aspect_ratio="square", model="janku")
+
+    assert result["success"] is True
+    assert result["provider"] == "civitai"
+    assert result["model"] == "janku"
+    assert result["image"] == "https://example.invalid/out.jpg"
+    assert result["buzz"] == 5
+    assert result["workflow_id"] == "wf_123"
+    assert result["width"] == 1024
+    assert result["height"] == 1024
+
+
+def test_generate_failed_workflow_surfaces_step_errors(monkeypatch):
+    from plugins.image_gen import civitai
+
+    monkeypatch.setenv("CIVITAI_API_KEY", "test-key")
+    monkeypatch.setattr(
+        civitai,
+        "_call_api",
+        lambda *_args, **_kwargs: {
+            "status": "failed",
+            "steps": [{"output": {"errors": ["bad AIR", "quota exhausted"]}}],
+        },
+    )
+
+    result = CivitaiImageGenProvider().generate("draw")
+
+    assert result["success"] is False
+    assert result["error_type"] == "api_error"
+    assert result["error"] == "bad AIR; quota exhausted"
+
+
+def test_call_api_uses_curl_without_proxy_env(monkeypatch):
+    from plugins.image_gen import civitai
+
