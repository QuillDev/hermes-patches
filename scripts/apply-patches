#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"
REF="$BASE_COMMIT"
while [[ $# -gt 0 ]]; do
  case "$1" in
    --latest) REF="refs/heads/$UPSTREAM_BRANCH"; shift ;;
    --base) REF="${2:-}"; shift 2 ;;
    -h|--help) echo "usage: scripts/apply-patches [--latest|--base <ref>]"; exit 0 ;;
    *) die "unknown argument: $1" ;;
  esac
done
ensure_upstream_cache
step "Creating patched worktree from $REF"
add_detached_worktree "$PATCHED_WORKTREE" "$REF"
step "Applying patch series"
if apply_series_in "$PATCHED_WORKTREE"; then
  ok "patches applied to $PATCHED_WORKTREE"
else
  warn "patch application failed; worktree left at $PATCHED_WORKTREE"
  warn "repair there, then run scripts/rebuild-patches"
  exit 1
fi
