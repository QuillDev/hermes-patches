#!/usr/bin/env bash
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/lib/common.sh"
if [[ ! -d "$PATCHED_WORKTREE/.git" && ! -f "$PATCHED_WORKTREE/.git" ]]; then
  "$REPO_ROOT/scripts/apply-patches"
fi
cd "$PATCHED_WORKTREE"
if command -v uv >/dev/null 2>&1; then
  uv sync --extra dev --extra messaging >/dev/null
fi
if [[ $# -gt 0 ]]; then
  exec bash -lc "$RUN_CMD $*"
else
  exec bash -lc "$RUN_CMD"
fi
